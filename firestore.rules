rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Super-admin: dono do STRONILEAD (claim `superAdmin` no token). Pode ler
    // o registro de qualquer tenant. Escritas seguem via Admin SDK (api/).
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.superAdmin == true;
    }

    // Multi-tenant: o usuário só acessa o tenant gravado no seu custom claim.
    // `appId` é o segmento de path do tenant. O claim é emitido no provisionamento
    // (api/) e no backfill; só atualiza no refresh do token (~1h ou re-login).
    function inTenant(appId) {
      return isSignedIn() && request.auth.token.tenantId == appId;
    }

    // Bloqueio server-side de academias SUSPENSAS ou com TRIAL EXPIRADO — espelha
    // a checagem feita no login (App.jsx). FAIL-OPEN: se o doc /tenants/{appId}
    // não existir (tenant legado) ou não tiver `status`, LIBERA; só NEGA quando o
    // status é explicitamente 'suspended' ou um trial com `trialEndsAt` no passado.
    // Usa exists()+get() (sem ambiguidade); `||` faz short-circuit e o get() só
    // roda quando o doc existe.
    function tenantNotBlocked(d) {
      return !('status' in d)
        || (d.status != 'suspended'
            && !(d.status == 'trial'
                 && 'trialEndsAt' in d
                 && d.trialEndsAt is timestamp
                 && d.trialEndsAt < request.time));
    }
    function tenantActive(appId) {
      return !exists(/databases/$(database)/documents/tenants/$(appId))
        || tenantNotBlocked(get(/databases/$(database)/documents/tenants/$(appId)).data);
    }

    function userDoc(appId) {
      return get(/databases/$(database)/documents/artifacts/$(appId)/public/data/stronix_users/$(request.auth.uid));
    }

    function isAdmin(appId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/stronix_users/$(request.auth.uid))
        && userDoc(appId).data.role == 'admin';
    }

    function ownsLead(appId, lead) {
      return isSignedIn() && lead.consultantAuthUid == request.auth.uid;
    }

    match /artifacts/{appId}/public/data/stronix_leads/{leadId} {
      allow read: if inTenant(appId) && tenantActive(appId) && (isAdmin(appId) || ownsLead(appId, resource.data));
      allow create: if inTenant(appId) && tenantActive(appId)
        && (isAdmin(appId) || request.resource.data.consultantAuthUid == request.auth.uid);
      allow update, delete: if inTenant(appId) && tenantActive(appId) && (isAdmin(appId) || ownsLead(appId, resource.data));
    }

    match /artifacts/{appId}/public/data/stronix_interactions/{id} {
      allow read: if inTenant(appId) && tenantActive(appId)
        && (isAdmin(appId) || resource.data.leadConsultantAuthUid == request.auth.uid);
      allow create: if inTenant(appId) && tenantActive(appId)
        && (isAdmin(appId) || request.resource.data.leadConsultantAuthUid == request.auth.uid);
      allow update, delete: if inTenant(appId) && tenantActive(appId)
        && (isAdmin(appId) || resource.data.leadConsultantAuthUid == request.auth.uid);
    }

    // stronix_users: NÃO usa tenantActive — o login precisa ler/vincular o doc do
    // próprio usuário mesmo para conseguir mostrar a tela de bloqueio. O self-update
    // já é travado (role/tenantId imutáveis) contra escalada de privilégio.
    match /artifacts/{appId}/public/data/stronix_users/{userId} {
      allow read: if inTenant(appId);
      allow write: if isAdmin(appId) && inTenant(appId);
      // o próprio usuário pode atualizar o próprio doc (ex.: vínculo de authUid no
      // login), MAS sem alterar campos sensíveis (role/tenantId) — caso contrário
      // um consultor poderia se autopromover a admin editando o próprio doc.
      allow update: if inTenant(appId) && request.auth.uid == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.tenantId == resource.data.tenantId;
    }

    match /artifacts/{appId}/public/data/stronix_sources/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_statuses/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_tags/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_loss_reasons/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_funnels/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_modalities/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_units/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    // Config geral da academia (doc único "general").
    match /artifacts/{appId}/public/data/stronix_config/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    // Registro de tenants (raiz). Escrita SEMPRE via Admin SDK (provisionamento,
    // status, convites) — nunca pelo cliente. Leitura liberada para os membros
    // do próprio tenant (o app lê status/trial no login para bloquear academias
    // suspensas/expiradas — por isso NÃO usa tenantActive aqui) e para o super-admin.
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || inTenant(tenantId);
      allow write: if false;

      // Convites do tenant. Escrita só via Admin SDK (invite-create/invite-accept).
      // Leitura: admin do tenant (para listar convites pendentes) ou super-admin.
      match /invites/{inviteId} {
        allow read: if isSuperAdmin() || isAdmin(tenantId);
        allow write: if false;
      }
    }
  }
}
