rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Super-admin: dono do STRONILEAD (claim `superAdmin` no token). Pode ler
    // o registro de qualquer tenant. Escritas seguem via Admin SDK (api/).
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.superAdmin == true;
    }

    // Multi-tenant: o usuário só acessa o tenant gravado no seu custom claim.
    // `appId` é o segmento de path do tenant. O claim é emitido no provisionamento
    // (api/) e no backfill; só atualiza no refresh do token (~1h ou re-login).
    function inTenant(appId) {
      return isSignedIn() && request.auth.token.tenantId == appId;
    }

    // Bloqueio server-side de academias SUSPENSAS ou com TRIAL EXPIRADO — espelha
    // a checagem feita no login (App.jsx). FAIL-OPEN: se o doc /tenants/{appId}
    // não existir (tenant legado) ou não tiver `status`, LIBERA; só NEGA quando o
    // status é explicitamente 'suspended' ou um trial com `trialEndsAt` no passado.
    // Usa exists()+get() (sem ambiguidade); `||` faz short-circuit e o get() só
    // roda quando o doc existe.
    // Inadimplência além da carência (3 dias) também bloqueia — espelha o app.
    // Pagar (webhook → paymentStatus 'paid' + limpa paymentOverdueSince) libera.
    function paymentBlocked(d) {
      return ('paymentStatus' in d) && d.paymentStatus == 'overdue'
        && ('paymentOverdueSince' in d) && d.paymentOverdueSince is timestamp
        && request.time - d.paymentOverdueSince > duration.value(3, 'd');
    }
    function tenantNotBlocked(d) {
      return (!('status' in d)
        || (d.status != 'suspended'
            && !(d.status == 'trial'
                 && 'trialEndsAt' in d
                 && d.trialEndsAt is timestamp
                 && d.trialEndsAt < request.time)))
        && !paymentBlocked(d);
    }
    function tenantActive(appId) {
      return !exists(/databases/$(database)/documents/tenants/$(appId))
        || tenantNotBlocked(get(/databases/$(database)/documents/tenants/$(appId)).data);
    }

    function userDoc(appId) {
      return get(/databases/$(database)/documents/artifacts/$(appId)/public/data/stronix_users/$(request.auth.uid));
    }

    function isAdmin(appId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/stronix_users/$(request.auth.uid))
        && userDoc(appId).data.role == 'admin';
    }

    function ownsLead(appId, lead) {
      return isSignedIn() && lead.consultantAuthUid == request.auth.uid;
    }

    // Base COMPARTILHADA: qualquer membro do tenant lê/cria/edita leads (1 lead por
    // pessoa, acessível por todos). O DONO (consultantAuthUid) é preservado — só
    // admin pode trocar o dono. Excluir: dono ou admin.
    match /artifacts/{appId}/public/data/stronix_leads/{leadId} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow create: if inTenant(appId) && tenantActive(appId)
        && (isAdmin(appId) || request.resource.data.consultantAuthUid == request.auth.uid);
      allow update: if inTenant(appId) && tenantActive(appId)
        && (isAdmin(appId) || request.resource.data.consultantAuthUid == resource.data.consultantAuthUid);
      allow delete: if inTenant(appId) && tenantActive(appId) && (isAdmin(appId) || ownsLead(appId, resource.data));
    }

    // Interações compartilhadas: qualquer membro lê e registra (ex.: agendar num
    // lead de outro consultor). Editar/remover: o autor da interação ou admin.
    match /artifacts/{appId}/public/data/stronix_interactions/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow create: if inTenant(appId) && tenantActive(appId);
      allow update, delete: if inTenant(appId) && tenantActive(appId)
        && (isAdmin(appId) || resource.data.consultantAuthUid == request.auth.uid);
    }

    // stronix_users: NÃO usa tenantActive — o login precisa ler/vincular o doc do
    // próprio usuário mesmo para conseguir mostrar a tela de bloqueio. O self-update
    // já é travado (role/tenantId imutáveis) contra escalada de privilégio.
    match /artifacts/{appId}/public/data/stronix_users/{userId} {
      allow read: if inTenant(appId);
      allow write: if isAdmin(appId) && inTenant(appId);
      // o próprio usuário pode atualizar o próprio doc (ex.: vínculo de authUid no
      // login), MAS sem alterar campos sensíveis (role/tenantId) — caso contrário
      // um consultor poderia se autopromover a admin editando o próprio doc.
      allow update: if inTenant(appId) && request.auth.uid == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.tenantId == resource.data.tenantId;
    }

    match /artifacts/{appId}/public/data/stronix_sources/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_statuses/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_tags/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_loss_reasons/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_dores/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_funnels/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_modalities/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_units/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    match /artifacts/{appId}/public/data/stronix_professores/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    // Catálogo de planos/serviços oferecidos na matrícula (feature lead→cliente).
    // Mesmo padrão dos demais catálogos: lê quem é do tenant, escreve só admin.
    match /artifacts/{appId}/public/data/stronix_planos/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    // Config geral da academia (doc único "general").
    match /artifacts/{appId}/public/data/stronix_config/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow write: if isAdmin(appId) && inTenant(appId) && tenantActive(appId);
    }

    // Histórico do "Ritmo do mês" da Meta Diária. Cada consultor grava só os
    // seus próprios dias (consultantAuthUid == uid); admin lê os de todos.
    // Não há delete (o histórico é imutável). ID = `${consultantId}_${data}`.
    match /artifacts/{appId}/public/data/stronix_daily_goal_history/{id} {
      allow read: if inTenant(appId) && tenantActive(appId)
        && (isAdmin(appId) || resource.data.consultantAuthUid == request.auth.uid);
      allow create, update: if inTenant(appId) && tenantActive(appId)
        && request.resource.data.consultantAuthUid == request.auth.uid;
      allow delete: if false;
    }

    // Contratos de matrícula (feature lead→cliente). Histórico imutável: 1 doc
    // por matrícula e por renovação, ligado ao lead por leadId. Qualquer membro
    // do tenant lê; cria/edita o DONO do lead (consultantAuthUid) ou admin.
    // Sem delete pelo cliente — o histórico não se apaga (igual ao daily_goal_history).
    match /artifacts/{appId}/public/data/stronix_contratos/{id} {
      allow read: if inTenant(appId) && tenantActive(appId);
      allow create: if inTenant(appId) && tenantActive(appId)
        && (isAdmin(appId) || request.resource.data.consultantAuthUid == request.auth.uid);
      allow update: if inTenant(appId) && tenantActive(appId)
        && (isAdmin(appId) || resource.data.consultantAuthUid == request.auth.uid);
      allow delete: if false;
    }

    // Registro de tenants (raiz). Escrita SEMPRE via Admin SDK (provisionamento,
    // status, convites) — nunca pelo cliente. Leitura liberada para os membros
    // do próprio tenant (o app lê status/trial no login para bloquear academias
    // suspensas/expiradas — por isso NÃO usa tenantActive aqui) e para o super-admin.
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || inTenant(tenantId);
      allow write: if false;

      // Convites do tenant. Escrita só via Admin SDK (invite-create/invite-accept).
      // Leitura: admin do tenant (para listar convites pendentes) ou super-admin.
      match /invites/{inviteId} {
        allow read: if isSuperAdmin() || isAdmin(tenantId);
        allow write: if false;
      }
    }

    // Log de auditoria do super-admin (provisionamento, status, "entrar como").
    // Escrita SEMPRE via Admin SDK (api/_audit.js); leitura só super-admin.
    match /superadmin_audit/{entryId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // Cobrança Asaas: idempotência dos webhooks + histórico de pagamentos.
    // Escrita SEMPRE via Admin SDK (api/asaas.js); leitura só super-admin.
    match /asaas_events/{eventId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }
    match /tenant_payments/{payId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // Feature flags da plataforma. O Console (super-admin) gerencia DIRETO pelo
    // client SDK (write só super-admin); o app lê p/ liberar funcionalidades.
    match /flags/{flagId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Tickets de suporte. O tenant abre/lê os seus; o super-admin gerencia todos.
    match /tickets/{ticketId} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.tenantId == request.auth.token.tenantId);
      allow create: if isSuperAdmin() || (isSignedIn() && request.resource.data.tenantId == request.auth.token.tenantId);
      // Cliente conversa no próprio ticket: só campos da thread/leitura,
      // sem trocar tenantId (reabrir ticket resolvido muda `status`).
      allow update: if isSuperAdmin() || (
        isSignedIn()
        && resource.data.tenantId == request.auth.token.tenantId
        && request.resource.data.tenantId == resource.data.tenantId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['mensagens', 'lastMsgAt', 'lastMsgBy', 'clienteLeuEmMs', 'status', 'updatedAt'])
      );
      allow delete: if isSuperAdmin();
    }
  }
}
