# ============================================================
# STRONILEAD — variáveis de ambiente
# ============================================================
# Copie para .env.local (NÃO commitar). No Vercel, configure as
# mesmas chaves em Project Settings → Environment Variables.

# ---- Firebase Web (frontend / Vite) --------------------------------
# Valores PÚBLICOS (embarcam no bundle). Opcionais: o app cai nos
# valores do projeto crm-stronix se não definidos (ver src/lib/firebase.js).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ---- Firebase Admin SDK (backend / pasta api/) ---------------------
# SECRETOS. Usados pelas serverless functions (api/_firebaseAdmin.js).
# A private key deve manter os \n escapados (uma linha só, entre aspas).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
