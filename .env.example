# ============================================================
# STRONILEAD — variáveis de ambiente
# ============================================================
# Copie para .env.local (NÃO commitar). No Vercel, configure as
# mesmas chaves em Project Settings → Environment Variables.

# ---- Firebase Web (frontend / Vite) --------------------------------
# Valores PÚBLICOS (embarcam no bundle). Opcionais: o app cai nos
# valores do projeto crm-stronix se não definidos (ver src/lib/firebase.js).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ---- Firebase Admin SDK (backend / pasta api/) ---------------------
# SECRETOS. Usados pelas serverless functions (api/_firebaseAdmin.js).
# A private key deve manter os \n escapados (uma linha só, entre aspas).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Asaas (gateway de cobrança recorrente / backend) --------------
# SECRETOS — só no backend, NUNCA no bundle. Sem ASAAS_API_KEY, a integração
# fica desligada (a UI mostra "não configurado" e a cobrança manual segue).
# Sandbox: chave com prefixo $aact_hmlg_ + base de sandbox abaixo.
# Produção: troque para a chave $aact_prod_ e ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_USER_AGENT=stronilead-crm
# Segredo do webhook (32–255 chars, sem espaços). DEVE ser igual ao authToken
# cadastrado no webhook do Asaas — o handler valida o header asaas-access-token.
ASAAS_WEBHOOK_TOKEN=
